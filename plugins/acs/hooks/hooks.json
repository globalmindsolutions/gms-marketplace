{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/dispatch.py\" pre",
            "timeout": 30,
            "statusMessage": "acs: checking pipeline gates"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/dispatch.py\" session-end",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
